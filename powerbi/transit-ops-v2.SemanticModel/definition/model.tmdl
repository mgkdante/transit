model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["DimProvider", "DimDate", "DimRoute", "DimStop", "DimDirection", "LatestVehicleSnapshot", "LatestTripDelaySnapshot", "CurrentVehicleMap", "CurrentTripDelayComputed", "CurrentI3Alerts", "FeedFreshnessCurrent", "SourceLineageReporting", "FactVehicleSnapshot", "FactTripDelaySnapshot", "FactStopTimeDelayObservation", "VehicleSummary5m", "TripDelaySummary5m", "TripDelaySummary5mLive", "PublicRouteReliabilityDaily", "PublicStopDelayDaily", "PublicAlertImpactDaily", "I3AlertHistoryReporting", "RouteDelayHourly", "RouteDelayDayOfWeek", "StopDelayHourly", "RouteReliabilityWeekly", "RouteReliabilityMonthly", "StopDelayWeekly", "StopDelayMonthly", "RouteHabitScore", "RepeatedProblemRouteStop", "CitizenAccountabilityDaily", "ReportLabels", "_Measures"]

annotation PBI_ProTooling = ["DevMode"]

ref table DimProvider
ref table DimDate
ref table DimRoute
ref table DimStop
ref table DimDirection
ref table LatestVehicleSnapshot
ref table LatestTripDelaySnapshot
ref table CurrentVehicleMap
ref table CurrentTripDelayComputed
ref table CurrentI3Alerts
ref table FeedFreshnessCurrent
ref table SourceLineageReporting
ref table FactVehicleSnapshot
ref table FactTripDelaySnapshot
ref table FactStopTimeDelayObservation
ref table VehicleSummary5m
ref table TripDelaySummary5m
ref table TripDelaySummary5mLive
ref table PublicRouteReliabilityDaily
ref table PublicStopDelayDaily
ref table PublicAlertImpactDaily
ref table I3AlertHistoryReporting
ref table RouteDelayHourly
ref table RouteDelayDayOfWeek
ref table StopDelayHourly
ref table RouteReliabilityWeekly
ref table RouteReliabilityMonthly
ref table StopDelayWeekly
ref table StopDelayMonthly
ref table RouteHabitScore
ref table RepeatedProblemRouteStop
ref table CitizenAccountabilityDaily
ref table ReportLabels
ref table _Measures

ref cultureInfo en-US
