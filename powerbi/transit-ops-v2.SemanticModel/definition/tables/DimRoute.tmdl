table DimRoute

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column dataset_version_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: dataset_version_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column route_short_name
		dataType: string
		summarizeBy: none
		sourceColumn: route_short_name

		annotation SummarizationSetBy = Automatic

	column route_long_name
		dataType: string
		summarizeBy: none
		sourceColumn: route_long_name

		annotation SummarizationSetBy = Automatic

	column route_type
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: route_type

		annotation SummarizationSetBy = Automatic

	column route_color
		dataType: string
		summarizeBy: none
		sourceColumn: route_color

		annotation SummarizationSetBy = Automatic

	column route_text_color
		dataType: string
		summarizeBy: none
		sourceColumn: route_text_color

		annotation SummarizationSetBy = Automatic

	partition DimRoute = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_dim_route = Source{[Schema="gold",Item="dim_route"]}[Data]
				in
				    gold_dim_route

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
