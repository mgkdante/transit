table PublicAlertImpactDaily

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column stop_id
		dataType: string
		summarizeBy: none
		sourceColumn: stop_id

		annotation SummarizationSetBy = Automatic

	column area_id
		dataType: string
		summarizeBy: none
		sourceColumn: area_id

		annotation SummarizationSetBy = Automatic

	column provider_local_date
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: provider_local_date

		annotation SummarizationSetBy = Automatic

	column alert_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: alert_count

		annotation SummarizationSetBy = Automatic

	partition PublicAlertImpactDaily = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_public_alert_impact_daily = Source{[Schema="gold",Item="public_alert_impact_daily"]}[Data]
				in
				    gold_public_alert_impact_daily

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
