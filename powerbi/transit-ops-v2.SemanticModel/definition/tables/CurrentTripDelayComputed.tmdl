table CurrentTripDelayComputed

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column rt_feed_snapshot_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: rt_feed_snapshot_id

		annotation SummarizationSetBy = Automatic

	column trip_id
		dataType: string
		summarizeBy: none
		sourceColumn: trip_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column direction_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: direction_id

		annotation SummarizationSetBy = Automatic

	column captured_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: captured_at_utc

		annotation SummarizationSetBy = Automatic

	column stop_time_observation_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: stop_time_observation_count

		annotation SummarizationSetBy = Automatic

	column avg_delay_seconds
		dataType: double
		summarizeBy: sum
		sourceColumn: avg_delay_seconds

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column max_delay_seconds
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: max_delay_seconds

		annotation SummarizationSetBy = Automatic

	partition CurrentTripDelayComputed = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_current_trip_delay_computed = Source{[Schema="gold",Item="current_trip_delay_computed"]}[Data]
				in
				    gold_current_trip_delay_computed

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
