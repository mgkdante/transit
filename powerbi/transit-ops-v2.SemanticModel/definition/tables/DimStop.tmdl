table DimStop

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column dataset_version_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: dataset_version_id

		annotation SummarizationSetBy = Automatic

	column stop_id
		dataType: string
		summarizeBy: none
		sourceColumn: stop_id

		annotation SummarizationSetBy = Automatic

	column stop_code
		dataType: string
		summarizeBy: none
		sourceColumn: stop_code

		annotation SummarizationSetBy = Automatic

	column stop_name
		dataType: string
		summarizeBy: none
		sourceColumn: stop_name

		annotation SummarizationSetBy = Automatic

	column parent_station
		dataType: string
		summarizeBy: none
		sourceColumn: parent_station

		annotation SummarizationSetBy = Automatic

	column location_type
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: location_type

		annotation SummarizationSetBy = Automatic

	column stop_lat
		dataType: double
		summarizeBy: sum
		sourceColumn: stop_lat

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column stop_lon
		dataType: double
		summarizeBy: sum
		sourceColumn: stop_lon

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition DimStop = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_dim_stop = Source{[Schema="gold",Item="dim_stop"]}[Data]
				in
				    gold_dim_stop

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
