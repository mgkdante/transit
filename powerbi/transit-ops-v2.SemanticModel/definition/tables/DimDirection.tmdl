table DimDirection

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column direction_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: direction_id

		annotation SummarizationSetBy = Automatic

	column direction_label
		dataType: string
		summarizeBy: none
		sourceColumn: direction_label

		annotation SummarizationSetBy = Automatic

	partition DimDirection = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_dim_direction = Source{[Schema="gold",Item="dim_direction"]}[Data]
				in
				    gold_dim_direction

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
