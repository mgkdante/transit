table LatestVehicleSnapshot

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column realtime_snapshot_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: realtime_snapshot_id

		annotation SummarizationSetBy = Automatic

	column entity_index
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: entity_index

		annotation SummarizationSetBy = Automatic

	column feed_timestamp_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: feed_timestamp_utc

		annotation SummarizationSetBy = Automatic

	column captured_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: captured_at_utc

		annotation SummarizationSetBy = Automatic

	column vehicle_id
		dataType: string
		summarizeBy: none
		sourceColumn: vehicle_id

		annotation SummarizationSetBy = Automatic

	column trip_id
		dataType: string
		summarizeBy: none
		sourceColumn: trip_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column stop_id
		dataType: string
		summarizeBy: none
		sourceColumn: stop_id

		annotation SummarizationSetBy = Automatic

	column latitude
		dataType: double
		summarizeBy: sum
		sourceColumn: latitude

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column longitude
		dataType: double
		summarizeBy: sum
		sourceColumn: longitude

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition LatestVehicleSnapshot = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_latest_vehicle_snapshot = Source{[Schema="gold",Item="latest_vehicle_snapshot"]}[Data]
				in
				    gold_latest_vehicle_snapshot

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
