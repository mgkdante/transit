table DimProvider

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column provider_key
		dataType: string
		summarizeBy: none
		sourceColumn: provider_key

		annotation SummarizationSetBy = Automatic

	column display_name
		dataType: string
		summarizeBy: none
		sourceColumn: display_name

		annotation SummarizationSetBy = Automatic

	column timezone
		dataType: string
		summarizeBy: none
		sourceColumn: timezone

		annotation SummarizationSetBy = Automatic

	column default_language
		dataType: string
		summarizeBy: none
		sourceColumn: default_language

		annotation SummarizationSetBy = Automatic

	column is_active
		dataType: boolean
		summarizeBy: none
		sourceColumn: is_active

		annotation SummarizationSetBy = Automatic

	partition DimProvider = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_dim_provider = Source{[Schema="gold",Item="dim_provider"]}[Data]
				in
				    gold_dim_provider

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
