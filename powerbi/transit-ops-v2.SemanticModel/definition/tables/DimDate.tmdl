table DimDate

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column dataset_version_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: dataset_version_id

		annotation SummarizationSetBy = Automatic

	column service_date
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: service_date

		annotation SummarizationSetBy = Automatic

	column date_key
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: date_key

		annotation SummarizationSetBy = Automatic

	column day_of_week_iso
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: day_of_week_iso

		annotation SummarizationSetBy = Automatic

	column day_name
		dataType: string
		summarizeBy: none
		sourceColumn: day_name

		annotation SummarizationSetBy = Automatic

	column week_of_year
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: week_of_year

		annotation SummarizationSetBy = Automatic

	column month_number
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: month_number

		annotation SummarizationSetBy = Automatic

	column month_name
		dataType: string
		summarizeBy: none
		sourceColumn: month_name

		annotation SummarizationSetBy = Automatic

	column quarter_number
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: quarter_number

		annotation SummarizationSetBy = Automatic

	column year_number
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: year_number

		annotation SummarizationSetBy = Automatic

	column is_weekend
		dataType: boolean
		summarizeBy: none
		sourceColumn: is_weekend

		annotation SummarizationSetBy = Automatic

	column has_calendar_exception
		dataType: boolean
		summarizeBy: none
		sourceColumn: has_calendar_exception

		annotation SummarizationSetBy = Automatic

	column is_service_added
		dataType: boolean
		summarizeBy: none
		sourceColumn: is_service_added

		annotation SummarizationSetBy = Automatic

	column is_service_removed
		dataType: boolean
		summarizeBy: none
		sourceColumn: is_service_removed

		annotation SummarizationSetBy = Automatic

	partition DimDate = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_dim_date = Source{[Schema="gold",Item="dim_date"]}[Data]
				in
				    gold_dim_date

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
