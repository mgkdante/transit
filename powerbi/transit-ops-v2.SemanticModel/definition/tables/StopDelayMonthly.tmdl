table StopDelayMonthly

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column month_start_local
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: month_start_local

		annotation SummarizationSetBy = Automatic

	column stop_id
		dataType: string
		summarizeBy: none
		sourceColumn: stop_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column observation_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: observation_count

		annotation SummarizationSetBy = Automatic

	column avg_delay_seconds
		dataType: double
		summarizeBy: sum
		sourceColumn: avg_delay_seconds

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column severe_delay_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: severe_delay_count

		annotation SummarizationSetBy = Automatic

	column built_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: built_at_utc

		annotation SummarizationSetBy = Automatic

	partition StopDelayMonthly = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_stop_delay_monthly = Source{[Schema="gold",Item="stop_delay_monthly"]}[Data]
				in
				    gold_stop_delay_monthly

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
