table PublicRouteReliabilityDaily

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column provider_local_date
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: provider_local_date

		annotation SummarizationSetBy = Automatic

	column stop_time_observation_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: stop_time_observation_count

		annotation SummarizationSetBy = Automatic

	column avg_delay_seconds
		dataType: double
		summarizeBy: sum
		sourceColumn: avg_delay_seconds

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column severe_delay_observation_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: severe_delay_observation_count

		annotation SummarizationSetBy = Automatic

	partition PublicRouteReliabilityDaily = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_public_route_reliability_daily = Source{[Schema="gold",Item="public_route_reliability_daily"]}[Data]
				in
				    gold_public_route_reliability_daily

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
