table VehicleSummary5m

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column period_start_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: period_start_utc

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column vehicle_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: vehicle_count

		annotation SummarizationSetBy = Automatic

	column observation_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: observation_count

		annotation SummarizationSetBy = Automatic

	column snapshot_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: snapshot_count

		annotation SummarizationSetBy = Automatic

	column built_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: built_at_utc

		annotation SummarizationSetBy = Automatic

	partition VehicleSummary5m = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_vehicle_summary_5m = Source{[Schema="gold",Item="vehicle_summary_5m"]}[Data]
				in
				    gold_vehicle_summary_5m

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
