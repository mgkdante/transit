table RepeatedProblemRouteStop

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column entity_kind
		dataType: string
		summarizeBy: none
		sourceColumn: entity_kind

		annotation SummarizationSetBy = Automatic

	column entity_id
		dataType: string
		summarizeBy: none
		sourceColumn: entity_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column period_grain
		dataType: string
		summarizeBy: none
		sourceColumn: period_grain

		annotation SummarizationSetBy = Automatic

	column period_start_local
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: period_start_local

		annotation SummarizationSetBy = Automatic

	column issue_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: issue_count

		annotation SummarizationSetBy = Automatic

	column avg_delay_seconds
		dataType: double
		summarizeBy: sum
		sourceColumn: avg_delay_seconds

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column severity_label
		dataType: string
		summarizeBy: none
		sourceColumn: severity_label

		annotation SummarizationSetBy = Automatic

	column built_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: built_at_utc

		annotation SummarizationSetBy = Automatic

	partition RepeatedProblemRouteStop = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_repeated_problem_route_stop = Source{[Schema="gold",Item="repeated_problem_route_stop"]}[Data]
				in
				    gold_repeated_problem_route_stop

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
