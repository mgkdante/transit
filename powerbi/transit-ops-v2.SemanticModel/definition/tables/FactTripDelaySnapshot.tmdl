table FactTripDelaySnapshot

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column realtime_snapshot_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: realtime_snapshot_id

		annotation SummarizationSetBy = Automatic

	column entity_index
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: entity_index

		annotation SummarizationSetBy = Automatic

	column snapshot_date_key
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: snapshot_date_key

		annotation SummarizationSetBy = Automatic

	column snapshot_local_date
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: snapshot_local_date

		annotation SummarizationSetBy = Automatic

	column feed_timestamp_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: feed_timestamp_utc

		annotation SummarizationSetBy = Automatic

	column captured_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: captured_at_utc

		annotation SummarizationSetBy = Automatic

	column trip_id
		dataType: string
		summarizeBy: none
		sourceColumn: trip_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column direction_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: direction_id

		annotation SummarizationSetBy = Automatic

	column vehicle_id
		dataType: string
		summarizeBy: none
		sourceColumn: vehicle_id

		annotation SummarizationSetBy = Automatic

	column delay_seconds
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: delay_seconds

		annotation SummarizationSetBy = Automatic

	column stop_time_update_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: stop_time_update_count

		annotation SummarizationSetBy = Automatic

	partition FactTripDelaySnapshot = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_fact_trip_delay_snapshot = Source{[Schema="gold",Item="fact_trip_delay_snapshot"]}[Data]
				in
				    gold_fact_trip_delay_snapshot

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
