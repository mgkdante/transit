table RouteDelayHourly

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column period_start_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: period_start_utc

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column trip_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: trip_count

		annotation SummarizationSetBy = Automatic

	column observation_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: observation_count

		annotation SummarizationSetBy = Automatic

	column avg_delay_seconds
		dataType: double
		summarizeBy: sum
		sourceColumn: avg_delay_seconds

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column max_delay_seconds
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: max_delay_seconds

		annotation SummarizationSetBy = Automatic

	column delayed_trip_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: delayed_trip_count

		annotation SummarizationSetBy = Automatic

	column severe_delay_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: severe_delay_count

		annotation SummarizationSetBy = Automatic

	column built_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: built_at_utc

		annotation SummarizationSetBy = Automatic

	partition RouteDelayHourly = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_route_delay_hourly = Source{[Schema="gold",Item="route_delay_hourly"]}[Data]
				in
				    gold_route_delay_hourly

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
