table RouteHabitScore

	column provider_id
		dataType: string
		summarizeBy: none
		sourceColumn: provider_id

		annotation SummarizationSetBy = Automatic

	column route_id
		dataType: string
		summarizeBy: none
		sourceColumn: route_id

		annotation SummarizationSetBy = Automatic

	column day_of_week_iso
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: day_of_week_iso

		annotation SummarizationSetBy = Automatic

	column hour_of_day_local
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: hour_of_day_local

		annotation SummarizationSetBy = Automatic

	column observation_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: observation_count

		annotation SummarizationSetBy = Automatic

	column avg_delay_seconds
		dataType: double
		summarizeBy: sum
		sourceColumn: avg_delay_seconds

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column severe_delay_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: severe_delay_count

		annotation SummarizationSetBy = Automatic

	column repeat_problem_score
		dataType: double
		summarizeBy: sum
		sourceColumn: repeat_problem_score

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column built_at_utc
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: built_at_utc

		annotation SummarizationSetBy = Automatic

	partition RouteHabitScore = m
		mode: directQuery
		source =
				let
				    Source = PostgreSQL.Database("db.transit.yesid.dev", "transit"),
				    gold_route_habit_score = Source{[Schema="gold",Item="route_habit_score"]}[Data]
				in
				    gold_route_habit_score

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table
