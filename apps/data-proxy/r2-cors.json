{
  "rules": [
    {
      "allowed": {
        "origins": ["*"],
        "methods": ["GET", "HEAD"],
        "headers": ["Range", "If-None-Match", "If-Modified-Since"]
      },
      "exposeHeaders": [
        "ETag",
        "Date",
        "Age",
        "Cache-Control",
        "Content-Length",
        "Content-Range",
        "Accept-Ranges",
        "Last-Modified"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
