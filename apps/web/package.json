{
	"name": "@transit/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tokens:build": "bun tools/tokens/build.ts",
		"og:build": "bun scripts/build-og.ts",
		"og:check": "bun scripts/build-og.ts --check",
		"icons:build": "bun scripts/build-icons.ts",
		"icons:check": "bun scripts/build-icons.ts --check",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^22",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.8.9",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"satori": "^0.26.0",
		"sharp": "^0.34.5",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@lucide/svelte": "^1.18.0",
		"gsap": "^3.15.0",
		"maplibre-gl": "^5.24.0",
		"paneforge": "^1.0.2",
		"pmtiles": "^4.4.1",
		"svelte-sonner": "^1.1.1",
		"web-vitals": "^5.3.0",
		"zod": "^4.3.6"
	}
}
