# Cloudflare Pages _headers — response headers by path (slice-9.2 P5 deploy glue).
#
# This file is copied verbatim from static/ to the deploy root by
# adapter-cloudflare; Cloudflare Pages reads it to attach headers. First matching
# rule per header wins. Keep this in lockstep with CLOUDFLARE.md.
#
# CACHE DOCTRINE
#   /_app/immutable/*  content-hashed by SvelteKit  -> immutable, 1 year
#   /fonts/*           self-hosted, content-stable   -> immutable, 1 year
#   /og/*.png          rebuilt only when copy changes -> 1 day CDN, swr 1 week
#   /favicon.svg       stable brand mark              -> 1 week
#   /data/*            LIVE snapshot contract         -> NEVER cached here
#                      (the data.yesid.dev zone-route worker owns its own
#                       freshness headers; a CDN cache here would serve stale
#                       transit data — the cardinal sin of this app)

# Hashed build assets — safe to cache forever (filename changes on every edit).
/_app/immutable/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — content-stable, cache forever.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Open Graph cards — regenerated by scripts/build-og.ts only when copy changes.
# Short CDN TTL + stale-while-revalidate keeps social scrapers fast without
# pinning a stale card for a year.
/og/*
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800

# Brand favicon — stable, modest TTL.
/favicon.svg
  Cache-Control: public, max-age=604800

# Live snapshot contract — NEVER cached at this edge. Belt-and-suspenders:
# /data/* is served by the data.yesid.dev zone-route worker (dev proxy in
# vite.config.ts), so this app should not normally emit /data/* itself — but if
# anything ever does, refuse to cache it. Freshness is the worker's job.
/data/*
  Cache-Control: no-store

# PWA remote kill-switch flag — MUST never be edge-cached, or the operator could
# not remotely disable a misbehaving service worker (a cached flag would pin the
# old value). The SW + client both fetch it with cache:'no-store'; belt-and-
# suspenders, refuse to cache it at the edge too.
/sw-kill.json
  Cache-Control: no-store

# Service worker script — keep the registration short-lived so a new deploy (and
# any fix / the in-SW kill logic) is picked up promptly rather than pinned.
/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate

# Offline fallback — content-stable shell page; modest TTL.
/offline.html
  Cache-Control: public, max-age=3600

# Baseline security headers for static ASSET responses (favicon, fonts,
# /_app/immutable). In Worker mode `_headers` only decorates assets — the
# SSR-rendered HTML documents get the same set from hooks.server.ts. Both pull
# from $lib/site/securityHeaders, kept in lockstep by securityHeaders.test.ts.
# NOTE: script-src keeps 'unsafe-inline' for the pre-paint theme IIFE in app.html
# and allows https://static.cloudflareinsights.com for Cloudflare Web Analytics;
# tightening to a hash/nonce-based script-src is a tracked follow-up.
# NOTE: img-src is narrowed off the old `https:` wildcard to 'self' data: blob:
# + the basemap host (defense-in-depth) + the OG-image origin. Cross-Origin-
# Resource-Policy is intentionally omitted (it would block social OG scrapes).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: accelerometer=(), bluetooth=(), camera=(), gyroscope=(), hid=(), magnetometer=(), microphone=(), payment=(), serial=(), usb=(), geolocation=(self)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: blob: https://protomaps.github.io https://transit.yesid.dev; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://transit.yesid.dev https://protomaps.github.io; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests
