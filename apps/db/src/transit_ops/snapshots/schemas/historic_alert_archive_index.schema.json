    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "total_alerts": {
      "minimum": 0,
      "title": "Total Alerts",
      "type": "integer"
    }
  },
  "required": [
    "generated_utc",
    "collection_generation_id",
    "first_available_date",
    "last_available_date",
    "total_alerts",
    "months"
