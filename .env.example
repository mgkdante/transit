# Transit root dotenv example.
#
# Keep `.env` as the single runtime file for the Python app and local CLI.
# `.env.1password` is the tracked inject source when you want to materialize a
# fresh local `.env`.

# Runtime environment for the local CLI.
APP_ENV=local

# Standard Python logging level.
LOG_LEVEL=INFO

# GitHub Actions secrets required after pushing the repo if you want the
# included daily static workflow to run successfully:
# - NEON_DATABASE_URL
# - BRONZE_S3_ACCESS_KEY
# - BRONZE_S3_SECRET_KEY
#
# Container/runtime secrets required for the realtime worker:
# - NEON_DATABASE_URL
# - STM_API_KEY
# - BRONZE_S3_ACCESS_KEY
# - BRONZE_S3_SECRET_KEY

# Neon Postgres connection string used by db-test, init-db, and seed-core.
NEON_DATABASE_URL=

# Default provider timezone for STM and local reporting assumptions.
PROVIDER_TIMEZONE=America/Toronto

# STM provider identifier used across core tables.
STM_PROVIDER_ID=stm

# STM API key is required for live STM GTFS-RT capture.
STM_API_KEY=

# Optional overrides for provider-manifest feed URLs.
STM_STATIC_GTFS_URL=
STM_RT_TRIP_UPDATES_URL=
STM_RT_VEHICLE_POSITIONS_URL=

# Durable Bronze storage is intended to use Cloudflare R2 via the S3-compatible
# backend. Local disk can still be used for temp staging and older local-row
# compatibility, but new durable Bronze writes should target R2.
BRONZE_STORAGE_BACKEND=s3
BRONZE_LOCAL_ROOT=./data/bronze

# S3-compatible Bronze storage stays generic, but the intended durable target
# is Cloudflare R2. Use the account-level endpoint only. Do not include the
# bucket name in BRONZE_S3_ENDPOINT; keep BRONZE_S3_BUCKET separate.
BRONZE_S3_ENDPOINT=https://eccfb9bedd87d413eaf4cac6ae2285d3.r2.cloudflarestorage.com
BRONZE_S3_BUCKET=transit-raw
BRONZE_S3_ACCESS_KEY=
BRONZE_S3_SECRET_KEY=
BRONZE_S3_REGION=auto

# Realtime worker cadence controls. The default worker loop now runs one
# complete realtime cycle every 5 minutes so the service is not continuously
# locking or churning Gold while still staying near-real-time for dashboards.
REALTIME_POLL_SECONDS=300
REALTIME_STARTUP_DELAY_SECONDS=0

# Silver retention controls. Static GTFS keeps only the current dataset version
# by default, and realtime Silver keeps the most recent two days of snapshots.
STATIC_DATASET_RETENTION_COUNT=1
SILVER_REALTIME_RETENTION_DAYS=2

# Gold facts keep the most recent two days by default for quick local rebuilds.
GOLD_FACT_RETENTION_DAYS=2

# Bronze realtime snapshots keep one week by default.
BRONZE_REALTIME_RETENTION_DAYS=7

# Bronze static datasets keep the last 30 days by default.
BRONZE_STATIC_RETENTION_DAYS=30

# Warm Gold rollups keep the last 90 days by default.
GOLD_WARM_ROLLUP_RETENTION_DAYS=90

# workflow-overlord automation auth. Optional for local CLI usage, required if
# repo hook wrappers should be able to call Notion through direct REST.
#
# The Python app ignores this extra env var because Settings.model_config uses
# extra="ignore".
NOTION_INTEGRATION_TOKEN=
