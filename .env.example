# Transit root dotenv example.
#
# Keep `.env` as the single runtime file for the Python app and local CLI.
# `.env.1password` is the tracked inject source when you want to materialize a
# fresh local `.env`.

# Runtime environment for the local CLI.
APP_ENV=local

# Standard Python logging level.
LOG_LEVEL=INFO

# GitHub Actions secrets required after pushing the repo if you want the
# included daily static workflow to run successfully:
# - DATABASE_URL
# - BRONZE_S3_ACCESS_KEY
# - BRONZE_S3_SECRET_KEY
#
# Container/runtime secrets required for the realtime worker:
# - DATABASE_URL
# - STM_API_KEY
# - BRONZE_S3_ACCESS_KEY
# - BRONZE_S3_SECRET_KEY

# Primary Postgres connection string used by db-test, init-db, and seed-core.
DATABASE_URL=

# Compose Postgres defaults for local validation and Oracle VM Postgres deployments.
# Replace POSTGRES_PASSWORD before any VM deployment.
POSTGRES_DB=transit
POSTGRES_USER=transit
POSTGRES_PASSWORD=transit-local-password
POSTGRES_HOST_PORT=5432

# Compose Caddy defaults. Local development binds high host ports by default;
# the Oracle VM cutover slice can switch these to 80/443.
CADDY_SITE_ADDRESS=:80
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# Default provider timezone for STM and local reporting assumptions.
PROVIDER_TIMEZONE=America/Toronto

# STM provider identifier used across core tables.
STM_PROVIDER_ID=stm

# STM API key is required for live STM GTFS-RT capture.
STM_API_KEY=

# Active static GTFS URL override is optional. The default manifest uses the live
# current STM GTFS archive so realtime trip IDs can join to static stop_times.
STM_STATIC_GTFS_URL=
STM_RT_TRIP_UPDATES_URL=
STM_RT_VEHICLE_POSITIONS_URL=

# Durable Bronze storage is intended to use Cloudflare R2 via the S3-compatible
# backend. Local disk can still be used for temp staging and older local-row
# compatibility, but new durable Bronze writes should target R2.
BRONZE_STORAGE_BACKEND=s3
BRONZE_LOCAL_ROOT=./data/bronze

# S3-compatible Bronze storage stays generic, but the intended durable target
# is Cloudflare R2. Use the account-level endpoint only. Do not include the
# bucket name in BRONZE_S3_ENDPOINT; keep BRONZE_S3_BUCKET separate.
BRONZE_S3_ENDPOINT=https://eccfb9bedd87d413eaf4cac6ae2285d3.r2.cloudflarestorage.com
BRONZE_S3_BUCKET=transit-raw
BRONZE_S3_ACCESS_KEY=
BRONZE_S3_SECRET_KEY=
BRONZE_S3_REGION=auto

# Nightly logical Postgres backups stream pg_dump (custom format) straight to
# the private Bronze R2 bucket under BACKUP_S3_PREFIX with no VM disk staging.
# BACKUP_EXCLUDE_TABLE_DATA lists tables whose DATA is skipped (schema still
# dumped) because Bronze R2 can replay them; entries must exist in the live
# database or the backup aborts loudly. BACKUP_COMPRESSION is passed verbatim
# to pg_dump --compress (gzip fallback: set to a bare level such as 6).
BACKUP_S3_PREFIX=backups/postgres
BACKUP_RETENTION_COUNT=14
BACKUP_EXCLUDE_TABLE_DATA=silver.rt_trip_update_stop_times
BACKUP_COMPRESSION=zstd:3

# /v1 snapshot publisher — reuses BRONZE_S3_* credentials for R2 access.
# Prod publishes to the public R2 bucket below (served at the canonical URL).
# For offline dev set SNAPSHOT_STORAGE_BACKEND=local + SNAPSHOT_LOCAL_ROOT so
# dev runs never write to the production bucket.
SNAPSHOT_STORAGE_BACKEND=s3
SNAPSHOT_R2_BUCKET=transit-snapshots
SNAPSHOT_PUBLIC_BASE_URL=https://transit.yesid.dev/data
SNAPSHOT_LOCAL_ROOT=

# Realtime worker cadence controls. The default worker loop targets one
# complete realtime cycle every 30 seconds for live dashboard freshness.
REALTIME_POLL_SECONDS=30
REALTIME_STARTUP_DELAY_SECONDS=0

# Health service checks should fail fast; freshness keeps a 15-minute failure
# window so short STM/API hiccups do not mark the runtime down immediately.
HEALTH_DATABASE_TIMEOUT_SECONDS=5.0
HEALTH_FEED_TIMEOUT_SECONDS=10.0
HEALTH_MAX_PIPELINE_AGE_SECONDS=900

# Retention defaults for the clean reporting contract: static GTFS keeps one
# current dataset in Silver, Bronze realtime keeps 30 days, Bronze static keeps
# 365 days, Silver realtime keeps 14 days, Gold facts keep 7 days, and Gold
# aggregate/reporting marts keep 365 days.
STATIC_DATASET_RETENTION_COUNT=1
SILVER_REALTIME_RETENTION_DAYS=14

GOLD_FACT_RETENTION_DAYS=14

BRONZE_REALTIME_RETENTION_DAYS=30

BRONZE_STATIC_RETENTION_DAYS=365

GOLD_WARM_ROLLUP_RETENTION_DAYS=365

# workflow-overlord automation auth. Optional for local CLI usage, required if
# repo hook wrappers should be able to call Notion through direct REST.
#
# The Python app ignores this extra env var because Settings.model_config uses
# extra="ignore".
NOTION_INTEGRATION_TOKEN=
